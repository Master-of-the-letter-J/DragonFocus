{
	"expo": {
		"name": "DragonFocus",
		"slug": "dragonfocus",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/icons/dragon-logo-placeholder.png",
		"scheme": "dragonfocus",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"splash": {
			"image": "./assets/icons/dragon-splash-image-placeholder.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.organizationj.dragonfocus"
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/icons/dragon-splash-image-android-placeholder.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.organizationj.dragonfocus"
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": ["expo-router"],
		"experiments": {
			"typedRoutes": true,
			"tsconfigPaths": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "d095969b-04a5-4055-bc8c-865c6a062cf2"
			}
		},
		"owner": "organization-j"
	}
}
